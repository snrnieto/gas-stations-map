{
  "expo": {
    "name": "gas-stations-map",
    "owner": "senira",
    "slug": "gas-stations-map",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sebastian.gasstationsmap"
    },
    "android": {
      "package": "com.sebastian.gasstationsmap",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite tomar una foto del tarifario de la estación para enviar los precios a verificación.",
          "microphonePermission": "El micrófono no es necesario para fotos de precios.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite elegir una foto de la galería con el tarifario de precios.",
          "cameraPermission": "Permite tomar una foto del tarifario de la estación."
        }
      ]
    ]
  }
}
